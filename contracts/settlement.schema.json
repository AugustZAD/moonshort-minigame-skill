{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonshort.local/contracts/settlement.schema.json",
  "title": "MiniGameSettlement",
  "type": "object",
  "required": [
    "rating",
    "score",
    "attribute",
    "modifier"
  ],
  "properties": {
    "rating": {
      "type": "string",
      "enum": [
        "S",
        "A",
        "B",
        "C"
      ]
    },
    "score": {
      "type": "number"
    },
    "attribute": {
      "type": "string",
      "minLength": 1
    },
    "modifier": {
      "type": "integer",
      "enum": [
        3,
        1,
        0,
        -1
      ]
    }
  },
  "additionalProperties": true
}
